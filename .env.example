# Build identity
PYXIS_DOMAIN=

# Opengateway (gitlawb's OpenAI-compatible LLM gateway, multi-provider routing)
# Sign in with X at https://gitlawb.com/opengateway/dashboard to generate ogw_live_ key.
# Free during partnership window; auth becoming required.
OPENGATEWAY_API_KEY=
OPENGATEWAY_BASE_URL=
OPENGATEWAY_MODEL=

# Tavily — news/narrative search (Scout & Sentinel only)
TAVILY_API_KEY=

# CoinMarketCap — optional fallback / cross-check for CoinGecko (free tier 10K credits/mo)
# If unset, Analyst dossier skips CMC source silently.
CMC_API_KEY=

# Etherscan V2 multi-chain (one key for ETH/Base/Arbitrum/Polygon/Optimism/BSC)
# Free tier 5 req/s · used for contract verification, token supply, holder concentration.
# If unset, on-chain sections silently skip.
ETHERSCAN_API_KEY=

# Solscan (Solana on-chain — token meta + holder distribution)
# If unset, Solana on-chain sections silently skip.
SOLSCAN_API_KEY=

# GetXAPI (Twitter analytics for Sentinel) — $0.001 per call
# Hard cap per Sentinel run via PYXIS_GETXAPI_MAX_CALLS (default 5 = $0.005 max/research)
# If GETXAPI_API_KEY unset, Sentinel falls back to Tavily + Reddit + F&G only.
GETXAPI_API_KEY=
PYXIS_GETXAPI_MAX_CALLS=

# x402 (Base mainnet — launch pricing)
# Set NEXT_PUBLIC_X402_FREE_MODE=true during beta to bypass the paywall.
# Toggle to false (or unset) at GA to resume paid mode without other config changes.
NEXT_PUBLIC_X402_FREE_MODE=
X402_NETWORK=
X402_PAY_TO=
X402_USDC_ADDRESS=
X402_PRICE_USDC=
X402_FACILITATOR_URL=

# SIWE
SIWE_JWT_SECRET=
SIWE_DOMAIN=

# Frontend
NEXT_PUBLIC_WALLETCONNECT_ID=
NEXT_PUBLIC_CHAIN=
NEXT_PUBLIC_APP_URL=

# Optional: override SQLite database path (defaults to ./data/probe.db)
# SQLITE_PATH=
