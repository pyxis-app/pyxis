# Build identity
PYXIS_DOMAIN=pyxis.app

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Tavily — news/narrative search (Scout & Sentinel only)
TAVILY_API_KEY=

# CoinMarketCap — optional fallback / cross-check for CoinGecko (free tier 10K credits/mo)
# If unset, Analyst dossier skips CMC source silently.
CMC_API_KEY=

# Etherscan V2 multi-chain (one key for ETH/Base/Arbitrum/Polygon/Optimism/BSC)
# Free tier 5 req/s · used for contract verification, token supply, holder concentration.
# If unset, on-chain sections silently skip.
ETHERSCAN_API_KEY=

# Solscan (Solana on-chain — token meta + holder distribution)
# If unset, Solana on-chain sections silently skip.
SOLSCAN_API_KEY=

# GetXAPI (Twitter analytics for Sentinel) — $0.001 per call
# Hard cap per Sentinel run via PYXIS_GETXAPI_MAX_CALLS (default 5 = $0.005 max/research)
# If GETXAPI_API_KEY unset, Sentinel falls back to Tavily + Reddit + F&G only.
GETXAPI_API_KEY=
PYXIS_GETXAPI_MAX_CALLS=5

# x402 (Base Sepolia)
X402_NETWORK=base-sepolia
X402_PAY_TO=0x0000000000000000000000000000000000000000
X402_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
X402_PRICE_USDC=0.25
X402_FACILITATOR_URL=https://x402.org/facilitator

# SIWE
SIWE_JWT_SECRET=
SIWE_DOMAIN=pyxis.app

# Frontend
NEXT_PUBLIC_WALLETCONNECT_ID=
NEXT_PUBLIC_CHAIN=base-sepolia
NEXT_PUBLIC_APP_URL=https://pyxis.app
